+
+        expert_owner = torch.div(flat_experts, self.num_local_experts, rounding_mode="floor")
+        local_expert_ids = flat_experts.remainder(self.num_local_experts)
+
+        if expert_owner.numel() > 0:
+            dest_order = torch.argsort(expert_owner)
+            expert_owner = expert_owner[dest_order]
+            local_expert_ids = local_expert_ids[dest_order]
+            flat_token_ids = flat_token_ids[dest_order]
+            flat_weights = flat_weights[dest_order]
+            flat_inputs = flat_inputs.index_select(0, dest_order).contiguous()
+
+        send_counts = torch.bincount(expert_owner, minlength=ep_size).to(torch.long)
+        recv_counts = torch.empty_like(send_counts)
+        dist.all_to_all_single(recv_counts, send_counts, group=self.ep_pg)
+        send_splits = send_counts.cpu().tolist()
+        recv_splits = recv_counts.cpu().tolist()
+        recv_total = int(recv_counts.sum().item())
+        _ep_mark("route_pack_and_count_exchange")
+
+        recv_meta = torch.empty((recv_total, 2), dtype=torch.long, device=device)
+
+        send_meta = torch.stack((flat_token_ids, local_expert_ids), dim=1).contiguous()
+        recv_inputs = _AllToAllSingle.apply(flat_inputs, recv_splits, send_splits, self.ep_pg)
+        recv_weights = _AllToAllSingle.apply(flat_weights, recv_splits, send_splits, self.ep_pg)
+        dist.all_to_all_single(
+            recv_meta,
+            send_meta,
+            output_split_sizes=recv_splits,
+            input_split_sizes=send_splits,
+            group=self.ep_pg,
+        )
+        _ep_mark("dispatch_alltoall")
+        recv_token_ids = recv_meta[:, 0]
+        recv_local_experts = recv_meta[:, 1]
+
+        if recv_total > 0:
+            expert_order = torch.argsort(recv_local_experts)
+            recv_inputs = recv_inputs.index_select(0, expert_order).contiguous()
+            recv_token_ids = recv_token_ids[expert_order]
+            recv_local_experts = recv_local_experts[expert_order]
+            recv_weights = recv_weights[expert_order]
+            num_tokens_per_local_expert = torch.bincount(
+                recv_local_experts, minlength=self.num_local_experts
+            ).to(torch.int64)
+            _ep_mark("expert_buffer_coalesce")
+            expert_outputs = self.experts(recv_inputs, num_tokens_per_local_expert)["hidden_states"]
+            _ep_mark("grouped_gemm")
+            expert_outputs = expert_outputs * recv_weights.to(expert_outputs.dtype).unsqueeze(-1)
+        else:
+            _ep_mark("expert_buffer_coalesce")
+            _ep_mark("grouped_gemm")
+            expert_outputs = torch.empty((0, hidden_size), dtype=hidden_states.dtype, device=device)
+            recv_token_ids = torch.empty((0,), dtype=torch.long, device=device)
+
+        return_owner = recv_token_ids.remainder(ep_size)
+        if return_owner.numel() > 0:
+            return_order = torch.argsort(return_owner)
+            return_owner = return_owner[return_order]
+            return_token_ids = recv_token_ids[return_order]
+            return_outputs = expert_outputs.index_select(0, return_order).contiguous()
+        else:
+            return_token_ids = recv_token_ids
+            return_outputs = expert_outputs
+
+        # The return path mirrors the first dispatch exactly: each expert rank sends
+        # every computed token back to its original owner. Therefore its send splits
+        # are the first dispatch's receive splits, and its receive splits are the
+        # first dispatch's send splits. Reusing them removes a second EP count
+        # exchange from every MoE layer.
+        return_send_splits = recv_splits
+        return_recv_splits = send_splits
+        return_recv_total = int(send_counts.sum().item())
+        _ep_mark("return_split_reuse")
+
+        recv_return_token_ids = torch.empty((return_recv_total,), dtype=torch.long, device=device)
+        recv_return_outputs = _AllToAllSingle.apply(
+            return_outputs, return_recv_splits, return_send_splits, self.ep_pg
+        )
+        dist.all_to_all_single(
+            recv_return_token_ids,
+            return_token_ids.contiguous(),
+            output_split_sizes=return_recv_splits,
+            input_split_sizes=return_send_splits,
+            group=self.ep_pg,
+        )
+        _ep_mark("return_alltoall")
+
+        output = torch.zeros_like(hidden_states)
+        if return_recv_total > 0:
+            output.scatter_add_(
+                0,
+                recv_return_token_ids.view(-1, 1).expand(-1, hidden_size),
+                recv_return_outputs,
+            )
+        _ep_mark("scatter")
+
+        # Some ranks/layers may receive no tokens for their local experts. Nanotron's
+        # gradient accumulator expects every parameter to have a grad tensor, so keep
+        # a zero-valued dependency on local expert weights for empty-dispatch cases.
+        output = output + 0.0 * (
+            self.experts.merged_gate_up_proj.sum() + self.experts.merged_down_proj.sum()
+        )
+
+        # Replicate token outputs for the existing non-EP layers.
+        output = _ReduceFromExpertParallel.apply(output, self.ep_pg)
+        _ep_mark("final_allreduce")
+        if profile_this_call and ep_rank == 0:
+            names = [
+                "route_pack_and_count_exchange",
+                "dispatch_alltoall",
+                "expert_buffer_coalesce",
+                "grouped_gemm",
+                "return_split_reuse",
+                "return_alltoall",
+                "scatter",
+                "final_allreduce",
+            ]
+            prev = profile_timestamps["start"]
+            parts = []
+            total_ms = (profile_timestamps["final_allreduce"] - prev) * 1000.0
+            for name in names:
+                current = profile_timestamps[name]
+                parts.append(f"{name}={(current - prev) * 1000.0:.3f}ms")
+                prev = current
+            logger.info(
+                "[EP alltoall profile] "
+                f"rank={ep_rank} call={self._ep_profile_calls - 1} "
+                f"tokens={num_tokens} recv={recv_total} return={return_recv_total} "
+                f"total={total_ms:.3f}ms | " + " | ".join(parts)
+            )
+        return output
+
     def _checkpointed_forward(self, hidden_states):
         """Apply gradient checkpointing to save memory during training."""
         return CheckpointFunction.apply(self._core_forward, True, hidden_states)
