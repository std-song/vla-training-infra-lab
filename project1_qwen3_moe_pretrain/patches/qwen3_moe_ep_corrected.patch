+class _AllToAllSingle(torch.autograd.Function):
+    """All-to-all for floating-point payloads with the inverse exchange in backward."""
+
+    @staticmethod
+    def forward(ctx, input_, output_splits, input_splits, group):
+        ctx.output_splits = tuple(output_splits)
+        ctx.input_splits = tuple(input_splits)
+        ctx.group = group
+        output = input_.new_empty((sum(output_splits), *input_.shape[1:]))
+        dist.all_to_all_single(
+            output,
+            input_.contiguous(),
+            output_split_sizes=list(output_splits),
+            input_split_sizes=list(input_splits),
+            group=group,
+        )
+        return output
+
+    @staticmethod
+    def backward(ctx, grad_output):
+        grad_input = grad_output.new_empty((sum(ctx.input_splits), *grad_output.shape[1:]))
+        dist.all_to_all_single(
+            grad_input,
+            grad_output.contiguous(),
+            output_split_sizes=list(ctx.input_splits),
+            input_split_sizes=list(ctx.output_splits),
+            group=ctx.group,
+        )
+        return grad_input, None, None, None
+
+
+class _ShardReplicatedTokens(torch.autograd.Function):
+    """Select locally owned tokens and restore their gradients on every EP rank."""
+
+    @staticmethod
+    def forward(ctx, input_, token_ids, group):
+        ctx.input_shape = input_.shape
+        ctx.group = group
+        ctx.save_for_backward(token_ids)
+        return input_.index_select(0, token_ids)
+
+    @staticmethod
+    def backward(ctx, grad_output):
+        (token_ids,) = ctx.saved_tensors
+        grad_input = grad_output.new_zeros(ctx.input_shape)
+        grad_input.index_add_(0, token_ids, grad_output)
+        dist.all_reduce(grad_input, group=ctx.group, op=dist.ReduceOp.SUM)
+        return grad_input, None, None
+
+
+class _ReduceFromExpertParallel(torch.autograd.Function):
+    """Replicate owner-sharded outputs; replicated downstream losses use identity backward."""
+
+    @staticmethod
+    def forward(ctx, input_, group):
+        output = input_.clone()
+        dist.all_reduce(output, group=group, op=dist.ReduceOp.SUM)
+        return output
+
+    @staticmethod
+    def backward(ctx, grad_output):
+        return grad_output, None
+
