+    def _core_forward_ep(self, hidden_states, routing_weights, routing_indices):
+        """Expert-parallel forward with token all-to-all dispatch.
+
+        This is a correctness-oriented token dispatcher:
+        1. Each EP rank owns a deterministic shard of input tokens.
+        2. Owner ranks send routed token copies to the rank that owns each expert.
+        3. Expert ranks coalesce received tokens by local expert and run GroupedGEMM.
+        4. Expert outputs are sent back to token owners and summed.
+        5. The final token outputs are all-reduced so replicated non-EP layers can continue.
+
+        The final all-reduce keeps the surrounding Qwen stack unchanged. A fully
+        optimized EP path would remove this replication point by making later
+        layers sequence-sharded or by adding a gather at the next boundary.
+        """
+        assert self.ep_pg is not None and self.ep_pg.size() == self.expert_parallel_size
+        ep_rank = dist.get_rank(self.ep_pg)
+        ep_size = self.ep_pg.size()
+        num_tokens, hidden_size = hidden_states.shape
+        device = hidden_states.device
+
+        token_ids_all = torch.arange(num_tokens, device=device, dtype=torch.long)
+        owner_mask = token_ids_all.remainder(ep_size) == ep_rank
+        owned_token_ids = token_ids_all[owner_mask]
+
+        flat_experts = routing_indices[owner_mask].reshape(-1).long()
+        flat_weights = routing_weights[owner_mask].reshape(-1)
+        flat_token_ids = owned_token_ids.repeat_interleave(self.num_experts_per_token)
+        flat_inputs = hidden_states.index_select(0, owned_token_ids).repeat_interleave(
+            self.num_experts_per_token, dim=0
+        )
+
+        expert_owner = torch.div(flat_experts, self.num_local_experts, rounding_mode="floor")
+        local_expert_ids = flat_experts.remainder(self.num_local_experts)
+
+        if expert_owner.numel() > 0:
+            dest_order = torch.argsort(expert_owner)
+            expert_owner = expert_owner[dest_order]
+            local_expert_ids = local_expert_ids[dest_order]
+            flat_token_ids = flat_token_ids[dest_order]
+            flat_weights = flat_weights[dest_order]
+            flat_inputs = flat_inputs.index_select(0, dest_order).contiguous()
+
+        send_counts = torch.bincount(expert_owner, minlength=ep_size).to(torch.long)
+        recv_counts = torch.empty_like(send_counts)
+        dist.all_to_all_single(recv_counts, send_counts, group=self.ep_pg)
+        send_splits = send_counts.cpu().tolist()
+        recv_splits = recv_counts.cpu().tolist()
+        recv_total = int(recv_counts.sum().item())
+
+        recv_inputs = torch.empty((recv_total, hidden_size), dtype=hidden_states.dtype, device=device)
+        recv_token_ids = torch.empty((recv_total,), dtype=torch.long, device=device)
+        recv_local_experts = torch.empty((recv_total,), dtype=torch.long, device=device)
+        recv_weights = torch.empty((recv_total,), dtype=routing_weights.dtype, device=device)
+
+        dist.all_to_all_single(
+            recv_inputs,
+            flat_inputs.contiguous(),
+            output_split_sizes=recv_splits,
+            input_split_sizes=send_splits,
+            group=self.ep_pg,
+        )
+        dist.all_to_all_single(
+            recv_token_ids,
+            flat_token_ids.contiguous(),
+            output_split_sizes=recv_splits,
+            input_split_sizes=send_splits,
+            group=self.ep_pg,
+        )
+        dist.all_to_all_single(
+            recv_local_experts,
+            local_expert_ids.contiguous(),
+            output_split_sizes=recv_splits,
+            input_split_sizes=send_splits,
+            group=self.ep_pg,
+        )
+        dist.all_to_all_single(
+            recv_weights,
+            flat_weights.contiguous(),
+            output_split_sizes=recv_splits,
+            input_split_sizes=send_splits,
+            group=self.ep_pg,
+        )
+
+        if recv_total > 0:
+            expert_order = torch.argsort(recv_local_experts)
+            recv_inputs = recv_inputs.index_select(0, expert_order).contiguous()
+            recv_token_ids = recv_token_ids[expert_order]
+            recv_local_experts = recv_local_experts[expert_order]
+            recv_weights = recv_weights[expert_order]
+            num_tokens_per_local_expert = torch.bincount(
+                recv_local_experts, minlength=self.num_local_experts
+            ).to(torch.int64)
+            expert_outputs = self.experts(recv_inputs, num_tokens_per_local_expert)["hidden_states"]
+            expert_outputs = expert_outputs * recv_weights.to(expert_outputs.dtype).unsqueeze(-1)
+        else:
+            expert_outputs = torch.empty((0, hidden_size), dtype=hidden_states.dtype, device=device)
+            recv_token_ids = torch.empty((0,), dtype=torch.long, device=device)
+
+        return_owner = recv_token_ids.remainder(ep_size)
+        if return_owner.numel() > 0:
+            return_order = torch.argsort(return_owner)
+            return_owner = return_owner[return_order]
+            return_token_ids = recv_token_ids[return_order]
+            return_outputs = expert_outputs.index_select(0, return_order).contiguous()
+        else:
+            return_token_ids = recv_token_ids
+            return_outputs = expert_outputs
+
+        return_send_counts = torch.bincount(return_owner, minlength=ep_size).to(torch.long)
+        return_recv_counts = torch.empty_like(return_send_counts)
+        dist.all_to_all_single(return_recv_counts, return_send_counts, group=self.ep_pg)
+        return_send_splits = return_send_counts.cpu().tolist()
+        return_recv_splits = return_recv_counts.cpu().tolist()
+        return_recv_total = int(return_recv_counts.sum().item())
+
+        recv_return_outputs = torch.empty(
+            (return_recv_total, hidden_size), dtype=hidden_states.dtype, device=device
+        )
+        recv_return_token_ids = torch.empty((return_recv_total,), dtype=torch.long, device=device)
+        dist.all_to_all_single(
+            recv_return_outputs,
+            return_outputs.contiguous(),
+            output_split_sizes=return_recv_splits,
+            input_split_sizes=return_send_splits,
+            group=self.ep_pg,
+        )
+        dist.all_to_all_single(
+            recv_return_token_ids,
+            return_token_ids.contiguous(),
+            output_split_sizes=return_recv_splits,
+            input_split_sizes=return_send_splits,
+            group=self.ep_pg,
+        )
+
+        output = torch.zeros_like(hidden_states)
+        if return_recv_total > 0:
+            output.scatter_add_(
+                0,
+                recv_return_token_ids.view(-1, 1).expand(-1, hidden_size),
+                recv_return_outputs,
+            )
+
+        # Some ranks/layers may receive no tokens for their local experts. Nanotron's
+        # gradient accumulator expects every parameter to have a grad tensor, so keep
+        # a zero-valued dependency on local expert weights for empty-dispatch cases.
+        output = output + 0.0 * (
+            self.experts.merged_gate_up_proj.sum() + self.experts.merged_down_proj.sum()
+        )
+
+        # Replicate token outputs for the existing non-EP layers.
+        dist.all_reduce(output, group=self.ep_pg, op=dist.ReduceOp.SUM)
+        return output
+
     def _checkpointed_forward(self, hidden_states):
         """Apply gradient checkpointing to save memory during training."""
         return CheckpointFunction.apply(self._core_forward, True, hidden_states)
