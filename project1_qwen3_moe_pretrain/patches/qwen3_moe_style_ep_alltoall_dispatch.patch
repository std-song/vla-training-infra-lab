+    def _compute_router_aux_loss(self, router_probs: torch.Tensor, routing_indices: torch.Tensor) -> torch.Tensor:
+        """Qwen3-style load-balance loss over the current batch, optionally all-reduced over DP."""
+        with torch.no_grad():
+            expert_mask = F.one_hot(routing_indices.long(), num_classes=self.num_experts).to(torch.float32)
+            tokens_per_expert = expert_mask.sum(dim=(0, 1))
+            denominator = torch.tensor(routing_indices.numel(), device=router_probs.device, dtype=torch.float32)
+
+        prob_sum_per_expert = router_probs.sum(dim=0)
+        prob_denominator = torch.tensor(router_probs.shape[0], device=router_probs.device, dtype=torch.float32)
+
+        if self.router_load_balancing_type == "global_batch" and self.dp_pg is not None and self.dp_pg.size() > 1:
+            dist.all_reduce(tokens_per_expert, group=self.dp_pg, op=dist.ReduceOp.SUM)
+            dist.all_reduce(denominator, group=self.dp_pg, op=dist.ReduceOp.SUM)
+            dist.all_reduce(prob_sum_per_expert, group=self.dp_pg, op=dist.ReduceOp.SUM)
+            dist.all_reduce(prob_denominator, group=self.dp_pg, op=dist.ReduceOp.SUM)
+
+        tokens_fraction = tokens_per_expert / denominator.clamp_min(1.0)
+        prob_mean = prob_sum_per_expert / prob_denominator.clamp_min(1.0)
+        load_balance_loss = self.num_experts * torch.sum(tokens_fraction * prob_mean)
+        return load_balance_loss.to(router_probs.dtype) * self.router_aux_loss_coef
+
